{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug C Program",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/tcc-debug", 
            "args": ["libtcc.c"], 
            "stopAtEntry": true,                          
            "cwd": "${workspaceFolder}",                
            "environment": [],
            "externalConsole": false,                      
            "MIMode": "gdb",                             
            "miDebuggerPath": "gdb",                       
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
